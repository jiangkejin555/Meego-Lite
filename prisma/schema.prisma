// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  avatar          String?
  feishuId        String?
  wecomId         String?
  // Notification preferences
  notifyEmail     Boolean  @default(true)
  notifyFeishu    Boolean  @default(false)
  notifyWeCom     Boolean  @default(false)
  feishuWebhook   String?
  wecomWebhook    String?
  // How many minutes before deadline to send reminder (default 60 min)
  leadTimeMinutes Int      @default(60)
  // AI report settings (per-user OpenAI credentials & summary preference)
  openaiApiKey       String?
  openaiBaseUrl      String?
  openaiModel        String?
  reportSummaryStyle String?
  // Auth: bcrypt password hash (optional, set when user has a password login)
  passwordHash    String?
  // Relations
  createdTasks    Task[]   @relation("TaskCreator")
  assignedTasks   Task[]   @relation("TaskAssignee")
  ownedProjects   Project[] @relation("ProjectOwners")
  createdProjects Project[] @relation("ProjectCreator")
  comments        Comment[]
  progressUpdates ProgressUpdate[]
  notifications   Notification[]
  reports         Report[]
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  // status: not_started | in_progress | done | paused
  status      String   @default("not_started")
  // priority: p0 | p1 | p2 | p3
  priority    String   @default("p2")
  owners      User[]   @relation("ProjectOwners")
  creatorId   String?
  creator     User?    @relation("ProjectCreator", fields: [creatorId], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?
  // status: todo | in_progress | testing | done | closed
  status         String       @default("todo")
  // priority: p0 | p1 | p2 | p3
  priority       String       @default("p2")
  deadline       DateTime?
  // Tags stored as JSON array string (SQLite doesn't support list type)
  tags           String?
  // Estimated & actual hours
  estimatedHours Float?
  actualHours    Float?
  // Relations
  creatorId      String
  assigneeId     String?
  projectId      String?
  creator        User         @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  project        Project?     @relation(fields: [projectId], references: [id])
  comments       Comment[]
  progressUpdates ProgressUpdate[]
  notifications  Notification[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ProgressUpdate {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  status    String
  content   String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  // type: deadline_reminder | assignment | status_change | mention
  type      String
  // channel: in_app | email | feishu | wecom
  channel   String
  title     String
  content   String
  // status: pending | sent | failed | read
  status    String    @default("pending")
  sentAt    DateTime?
  readAt    DateTime?
  error     String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  // purpose: register | login
  purpose   String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, purpose])
}

model Report {
  id        String   @id @default(cuid())
  userId    String
  // type: daily | weekly | custom
  type      String
  title     String
  startAt   DateTime
  endAt     DateTime
  // status: pending | done | failed
  status    String   @default("done")
  // error: 生成失败时的错误信息
  error     String?
  // content: Markdown 原文
  content   String
  // meta: JSON 字符串，冗余统计（任务/项目数量等），便于列表展示
  meta      String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}
