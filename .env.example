# ============================================================
# Meego Lite 环境变量示例
# 使用方法：复制本文件为 .env，按需修改值
#   cp .env.example .env
# ============================================================

# ===== 数据库 =====
# 默认本地 SQLite，无需修改
# 如需 PostgreSQL（云端部署），改成：
#   postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL="file:./dev.db"

# ===== NextAuth 鉴权（如启用登录） =====
# 用 `openssl rand -base64 32` 生成一串随机字符串
NEXTAUTH_SECRET="please-change-me-to-a-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ===== SMTP 邮件通知（可选，启用邮件渠道时必填） =====
# 以 QQ 邮箱为例：登录 QQ 邮箱 → 设置 → 账户 → 开启 IMAP/SMTP 服务 → 获取 16 位授权码
# 注意：
#   1) SMTP_FROM 中的邮箱必须等于 SMTP_USER，否则 QQ 邮箱会拒收
#   2) 不要使用 ${SMTP_USER} 这种变量插值写法，请直接写完整地址
#   3) 若 465 端口被封禁，可改用 SMTP_PORT=587 + SMTP_SECURE=false（STARTTLS）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_account@qq.com
SMTP_PASS=your_16_digit_auth_code
SMTP_FROM="Meego Lite <your_account@qq.com>"
